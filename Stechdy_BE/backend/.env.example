PORT=3001
MONGODB_URI=mongodb://mongodb:27017/Stechdy
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
NODE_ENV=development

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email Configuration (Optional - if not set, reset links will be logged to console)
# For Gmail: Enable 2FA and create an App Password
EMAIL_SERVICE=gmail
EMAIL_USER=your email here
EMAIL_PASSWORD=your email password here

# Cloudinary Configuration (Required for avatar uploads)
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL
FRONTEND_URL=https://stechdy.ai.vn

# Gemini AI API Key (used by backend AI chat endpoint)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
