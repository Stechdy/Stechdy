REACT_APP_API_URL=https://stechdy.ai.vn/api
REACT_APP_SOCKET_URL=https://stechdy.ai.vn
REACT_APP_ENV=production

# N8n Webhook URL for schedule generation
REACT_APP_N8N_WEBHOOK_URL=https://tamastran.duckdns.org/webhook/gen-schedule-v3-lite

# Google OAuth Configuration
# Get your Client ID from: https://console.cloud.google.com/apis/credentials
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Google Gemini AI API Key (for AI Chat feature)
# Get your API key from: https://makersuite.google.com/app/apikey
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Analytics and Tracking
# REACT_APP_GOOGLE_ANALYTICS_ID=
# REACT_APP_SENTRY_DSN=
